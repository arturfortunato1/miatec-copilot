# Copy to .env and fill in. The real .env is gitignored — never commit secrets.
# The backend loads these via python-dotenv. The stubbed demo runs with NONE of these set.

# ── LLM: resolution order is Vercel AI Gateway → Anthropic API → Amazon Bedrock ──
# Vercel AI Gateway (PRIMARY — satisfies the "integrate a Vercel AI product" requirement). Create a
# budgeted key: `npx vercel ai-gateway api-keys create --name miatec --budget 15 --refresh-period none`
AI_GATEWAY_API_KEY=
GATEWAY_MODEL=anthropic/claude-opus-4.8   # creator/model-name; e.g. anthropic/claude-sonnet-4.6 or openai/gpt-5.5
# Fast tier for the mechanical agents (Translate/Roles/Verifier) — keeps the demo snappy:
GATEWAY_MODEL_FAST=anthropic/claude-haiku-4.5   # (direct API: ANTHROPIC_MODEL_FAST; Bedrock: BEDROCK_MODEL_ID_FAST)
# Direct Anthropic API (fallback if no gateway key):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6        # Structuring; use claude-opus-4-8 for deeper Considerations reasoning
# — or — route via Amazon Bedrock: leave the keys blank, set AWS_* + this (NOTE: InvokeModel may be SCP-denied):
BEDROCK_MODEL_ID=

# ── AWS: Transcribe (Scribe), S3 (audio), Bedrock ─────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_AUDIO_BUCKET=
# Audio the cockpit's "Start consultation" runs on when no ref is posted (s3:// URI or local path):
DEFAULT_AUDIO_REF=
# Cache the parsed transcript per audio_ref so repeat demos are instant (set 0 to disable):
SCRIBE_CACHE=1
# pt-BR clinical custom vocabulary for Transcribe (provision: python -m app.vocab; empty to disable):
TRANSCRIBE_VOCABULARY_NAME=miatec-ptbr-clinical

# ── Exa: Evidence agent ───────────────────────────────────────
EXA_API_KEY=

# ── miatec: Record agent — the real write ─────────────────────
# DynamoDB staging table for approved encounters (create once: scripts/provision_miatec_table.sh).
# Needs AWS creds (or the Fargate task role). Unset → the Record agent simulates and says so.
MIATEC_TABLE=miatec-encounters
# Direct miatec REST write — slots into record.py when miatec exposes an API:
MIATEC_API_BASE=
MIATEC_API_KEY=

# ── App ───────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
