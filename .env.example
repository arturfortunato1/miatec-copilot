# Copy to .env and fill in. The real .env is gitignored — never commit secrets.
# The backend loads these via python-dotenv. The stubbed demo runs with NONE of these set.

# ── LLM: Claude (Anthropic) ───────────────────────────────────
# Direct Anthropic API (simplest):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6        # Structuring; use claude-opus-4-8 for deeper Considerations reasoning
# — or — route via Amazon Bedrock (counts as AWS sponsor tool use): leave the key blank, set AWS_* + this:
BEDROCK_MODEL_ID=

# ── AWS: Transcribe (Scribe), S3 (audio), Bedrock ─────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_AUDIO_BUCKET=

# ── Exa: Evidence agent ───────────────────────────────────────
EXA_API_KEY=

# ── miatec: Record agent (the moat) ───────────────────────────
MIATEC_API_BASE=
MIATEC_API_KEY=

# ── App ───────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
